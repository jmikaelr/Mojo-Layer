(ert-deftest mojo-test-mojo-command-quotes-target ()
  (cl-letf (((symbol-function 'mojo//resolve-mojo-command)
             (lambda () "mojo")))
    (let ((command (mojo//mojo-command "run"
                                       '("--target" "cpu")
                                       "/tmp/mojo project/main.mojo")))
      (should (string-match-p "^mojo run --target cpu " command))
      (should (string-match-p "/tmp/mojo\\\\ project/main\\.mojo$" command)))))

(ert-deftest mojo-test-resolve-mojo-command-prefers-pixi-run ()
  (let* ((root (make-temp-file "mojo-layer-" t))
         (mojo-use-project-pixi t)
         (project-mojo (expand-file-name ".pixi/envs/default/bin/mojo" root)))
    (make-directory (file-name-directory project-mojo) t)
    (with-temp-file project-mojo
      (insert "#!/bin/sh\n"))
    (set-file-modes project-mojo #o755)
    (cl-letf (((symbol-function 'mojo//project-root) (lambda () root))
              ((symbol-function 'executable-find)
               (lambda (name)
                 (when (string= name "pixi")
                   "/usr/bin/pixi"))))
      (should (string=
               (mojo//resolve-mojo-command)
               "pixi run mojo")))))

(ert-deftest mojo-test-resolve-mojo-command-falls-back-to-project-pixi-binary ()
  (let* ((root (make-temp-file "mojo-layer-" t))
         (mojo-use-project-pixi t)
         (project-mojo (expand-file-name ".pixi/envs/default/bin/mojo" root)))
    (make-directory (file-name-directory project-mojo) t)
    (with-temp-file project-mojo
      (insert "#!/bin/sh\n"))
    (set-file-modes project-mojo #o755)
    (cl-letf (((symbol-function 'mojo//project-root) (lambda () root))
              ((symbol-function 'executable-find)
               (lambda (_name) nil)))
      (should (string=
               (mojo//resolve-mojo-command)
               (shell-quote-argument project-mojo))))))

(ert-deftest mojo-test-resolve-mojo-command-uses-pixi-run ()
