(ert-deftest mojo-test-project-entrypoint-explicit ()
  (let ((root (make-temp-file "mojo-layer-" t))
        (mojo-run-project-entrypoint "src/my_main.mojo")
        (mojo-run-entrypoint-candidates '("main.mojo")))
    (cl-letf (((symbol-function 'mojo//project-root) (lambda () root)))
      (should (string=
               (mojo//project-entrypoint)
               (expand-file-name "src/my_main.mojo" root))))))

(ert-deftest mojo-test-project-entrypoint-autodetect ()
  (let* ((root (make-temp-file "mojo-layer-" t))
         (entrypoint (expand-file-name "src/main.mojo" root))
         (mojo-run-project-entrypoint nil)
         (mojo-run-entrypoint-candidates '("main.mojo" "src/main.mojo")))
    (make-directory (file-name-directory entrypoint) t)
    (with-temp-file entrypoint
      (insert "def main() raises:\n    pass\n"))
    (cl-letf (((symbol-function 'mojo//project-root) (lambda () root)))
      (should (string= (mojo//project-entrypoint) entrypoint)))))

(ert-deftest mojo-test-run-project-uses-entrypoint ()
  (let* ((root (make-temp-file "mojo-layer-" t))
         (entrypoint (expand-file-name "main.mojo" root))
         (captured nil)
         (mojo-run-arguments '("--target" "cpu"))
         (mojo-run-project-entrypoint "main.mojo")
         (mojo-use-project-pixi nil))
    (with-temp-file entrypoint
      (insert "def main() raises:\n    pass\n"))
    (cl-letf (((symbol-function 'compile)
               (lambda (command)
                 (setq captured command)
                 command))
              ((symbol-function 'executable-find)
               (lambda (name)
                 (when (string= name "mojo")
                   "mojo")))
              ((symbol-function 'mojo//project-root)
               (lambda () root)))
      (mojo/run-project)
      (should (equal captured
                     (format "mojo run --target cpu %s" entrypoint))))))

(ert-deftest mojo-test-build-project-uses-entrypoint ()
  (let* ((root (make-temp-file "mojo-layer-" t))
         (entrypoint (expand-file-name "src/main.mojo" root))
         (captured nil)
         (mojo-build-arguments '("--emit" "llvm"))
         (mojo-run-project-entrypoint "src/main.mojo")
         (mojo-use-project-pixi nil))
    (make-directory (file-name-directory entrypoint) t)
    (with-temp-file entrypoint
      (insert "def main() raises:\n    pass\n"))
    (cl-letf (((symbol-function 'compile)
               (lambda (command)
                 (setq captured command)
                 command))
              ((symbol-function 'executable-find)
               (lambda (name)
                 (when (string= name "mojo")
                   "mojo")))
              ((symbol-function 'mojo//project-root)
               (lambda () root)))
      (mojo/build-project)
      (should (equal captured
                     (format "mojo build --emit llvm %s" entrypoint))))))

(ert-deftest mojo-test-test-project-uses-mojo-run ()
  (let* ((root (make-temp-file "mojo-layer-" t))
         (tests-dir (expand-file-name "tests" root))
         (captured nil)
         (mojo-test-project-target nil)
         (mojo-test-target-candidates '("tests"))
         (mojo-test-add-project-include t)
         (mojo-test-arguments '("--warn-on-unstable-apis"))
         (mojo-use-project-pixi nil))
    (make-directory tests-dir t)
    (cl-letf (((symbol-function 'compile)
               (lambda (command)
                 (setq captured command)
                 command))
              ((symbol-function 'executable-find)
               (lambda (name)
                 (when (string= name "mojo")
                   "mojo")))
              ((symbol-function 'mojo//project-root)
               (lambda () root)))
      (mojo/test-project)
      (should (equal captured
                     (format "mojo run -I %s --warn-on-unstable-apis %s"
                             root
                             tests-dir))))))

(ert-deftest mojo-test-clean-project-uses-pixi-clean-default ()
  (let ((captured nil)
        (mojo-clean-command nil)
        (mojo-use-project-pixi t)
        (mojo-pixi-no-progress nil))
    (cl-letf (((symbol-function 'compile)
               (lambda (command)
                 (setq captured command)
                 command))
              ((symbol-function 'mojo//project-root)
               (lambda () "/tmp/mojo-layer-root"))
              ((symbol-function 'mojo//project-has-pixi-p)
               (lambda () t))
              ((symbol-function 'executable-find)
               (lambda (name)
                 (when (string= name "pixi")
                   "/usr/bin/pixi"))))
      (mojo/clean-project)
      (should (equal captured "pixi clean")))))

(ert-deftest mojo-test-test-dwim-prefers-test-file ()
  (let ((project-called nil)
        (file-called nil))
    (cl-letf (((symbol-function 'buffer-file-name)
               (lambda (&optional _buffer) "/tmp/project/tests/test_math.mojo"))
              ((symbol-function 'mojo/test-project)
               (lambda () (setq project-called t)))
              ((symbol-function 'mojo/test-file)
               (lambda (file) (setq file-called file))))
      (mojo/test-dwim)
      (should (string= file-called "/tmp/project/tests/test_math.mojo"))
      (should-not project-called))))

(ert-deftest mojo-test-test-dwim-falls-back-to-project ()
  (let ((project-called nil)
        (file-called nil))
    (cl-letf (((symbol-function 'buffer-file-name)
               (lambda (&optional _buffer) "/tmp/project/src/math.mojo"))
              ((symbol-function 'mojo/test-project)
               (lambda () (setq project-called t)))
              ((symbol-function 'mojo/test-file)
               (lambda (file) (setq file-called file))))
      (mojo/test-dwim)
      (should project-called)
      (should-not file-called))))

(ert-deftest mojo-test-retest-errors-without-history ()
  (let ((mojo--last-test-command nil))
    (should-error (mojo/retest) :type 'user-error)))

